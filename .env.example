# --- Backend API ---
# URL of deployed backend — no trailing slash
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# --- Supabase ---
# Get it at: Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Get it at: Supabase → Settings → API → anon/public key
# This is the SAFE public key — NOT the service_role key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_YOUR_SUPABASE_ANON_KEY_HERE

# Get it at: Supabase → Settings → API → service_role key
# Server-side only — used for data isolation queries in server components
# NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_KEY=eyJ_YOUR_SUPABASE_SERVICE_KEY_HERE

# --- Clerk ---
# Get it at: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY_HERE

# NEVER prefix this with NEXT_PUBLIC_ — it must stay server-side only
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY_HERE

# --- Stripe Subscription Plans ---
# Get from: Stripe Dashboard → Products → Pricing → Copy Price ID
# These are required for the /pricing page to create valid checkout sessions
NEXT_PUBLIC_STRIPE_PRICE_BASIC=price_YOUR_BASIC_PLAN_PRICE_ID_HERE
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_YOUR_PRO_PLAN_PRICE_ID_HERE

# Used by subscriptions.ts to determine if a user has the Pro plan
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_YOUR_PRO_PLAN_PRICE_ID_HERE

# --- Clerk Redirect URLs (Handled by modal-based OAuth) ---
# Sign-in/sign-up routes are NOT used — using useClerk().openSignIn() in-app
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
